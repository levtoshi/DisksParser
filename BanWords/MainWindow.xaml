<Window x:Class="BanWords.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BanWords"
        mc:Ignorable="d"
        Title="MainWindow" Height="800" Width="800" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="20"></Setter>
            <Setter Property="FontWeight" Value="SemiBold"></Setter>
            <Setter Property="Foreground" Value="White"></Setter>
            <Setter Property="Background" Value="ForestGreen"></Setter>
            <Setter Property="Margin" Value="30,15"></Setter>
            <Setter Property="Cursor" Value="Hand"></Setter>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Center"></Setter>
            <Setter Property="VerticalAlignment" Value="Center"></Setter>
            <Setter Property="FontSize" Value="32"></Setter>
            <Setter Property="FontWeight" Value="SemiBold"></Setter>
            <Setter Property="TextWrapping" Value="Wrap"></Setter>
            <Setter Property="Margin" Value="30,0"></Setter>
        </Style>
    </Window.Resources>
    <ScrollViewer>
        <Grid Height="1500">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.2*"></RowDefinition>
                <RowDefinition Height="0.2*"></RowDefinition>
                <RowDefinition Height="0.2*"></RowDefinition>
                <RowDefinition Height="0.2*"></RowDefinition>
                <RowDefinition Height="0.2*"></RowDefinition>
                <RowDefinition Height="0.4*"></RowDefinition>
                <RowDefinition Height="0.2*"></RowDefinition>
                <RowDefinition Height="1.5*"></RowDefinition>
            </Grid.RowDefinitions>

            <Button Grid.Row="0" x:Name="countFilesBt" Click="countFilesBt_Click">Count files</Button>

            <TextBlock Grid.Row="1" Name="timerCountFilesTb">00:00</TextBlock>
            
            <TextBlock Grid.Row="2" Name="totalFoldersTb" TextAlignment="Left">Total folders counted:</TextBlock>
            
            <TextBlock Grid.Row="3" Name="totalFilesTb" TextAlignment="Left">Total text files counted:</TextBlock>
            
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Name="initializeBannedBt" Click="initializeBannedBt_Click" IsEnabled="False">Initialize banned words</Button>
                <Button Grid.Column="1" Name="selectFolderForBannedBt" Click="selectFolderForBannedBt_Click" IsEnabled="False">Select folder to copy banned files</Button>
            </Grid>

            <ScrollViewer Grid.Row="5" Margin="20">
                <TextBlock Name="pathesTb" Margin="0" FontSize="20"></TextBlock>
            </ScrollViewer>

            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" x:Name="startBt" Click="startBt_Click" FontSize="28" FontWeight="Bold" IsEnabled="False">Start</Button>
                <Button Grid.Column="1" x:Name="stopBt" Click="stopBt_Click" FontSize="28" FontWeight="Bold" IsEnabled="False">Stop</Button>
                <Button Grid.Column="2" x:Name="abortBt" Click="abortBt_Click" FontSize="28" FontWeight="Bold" IsEnabled="False">Abort</Button>
            </Grid>

            <Grid Grid.Row="7" Margin="0,40,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition Height="1.2*"></RowDefinition>
                    <RowDefinition Height="1.2*"></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition Height="1.2*"></RowDefinition>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" FontWeight="Bold">Data Analysis</TextBlock>

                <TextBlock Grid.Row="1" FontWeight="Bold" Name="timerTb">00:00</TextBlock>

                <ProgressBar Grid.Row="2" Minimum="0" Value="0" Margin="50,20" Name="mainProgressBar"></ProgressBar>

                <TextBlock Grid.Row="3" TextAlignment="Left" Name="disksCheckedTb">Disks checked:</TextBlock>
                
                <TextBlock Grid.Row="4" FontSize="32" TextAlignment="Left" Name="foldersCheckedTb">Total folders checked:</TextBlock>
                
                <TextBlock Grid.Row="5" FontSize="32" TextAlignment="Left" Name="filesCheckedTb">Total text files checked:</TextBlock>
                
                <TextBlock Grid.Row="6" FontSize="32" TextAlignment="Left" Name="filesBannedTb">Total files banned:</TextBlock>
                
                <TextBlock Grid.Row="7" FontSize="32" TextAlignment="Left" Name="wordsHiddenTb">Total words hidden:</TextBlock>
                
                <Button Grid.Row="8" Name="moreInfoBt" Click="moreInfoBt_Click" FontSize="28" FontWeight="Bold" IsEnabled="False">More Info</Button>
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>
